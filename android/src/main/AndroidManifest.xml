<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Health Connect permissions -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />

    <!-- Required so openBatteryOptimizationSettings can launch the per-app
         whitelist dialog (ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS).
         Note: Play Console flags this; justification is the Health Connect
         change-token WorkManager pipeline, which loses data when deferred. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    
    <!-- Health Connect intent filters -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
        <!-- Play Store, so the install fallback in openHealthConnectSettings
             (market://details?id=...) resolves on Android 11+ devices. -->
        <package android:name="com.android.vending" />
        <!-- OEM safety-center packages so the diagnostic screen can deep-link
             into auto-launch / background-activity settings on aggressive ROMs
             (ColorOS, MIUI, EMUI, OnePlus, Vivo). -->
        <package android:name="com.coloros.safecenter" />
        <package android:name="com.coloros.oppoguardelf" />
        <package android:name="com.oppo.safe" />
        <package android:name="com.miui.securitycenter" />
        <package android:name="com.huawei.systemmanager" />
        <package android:name="com.oneplus.security" />
        <package android:name="com.iqoo.secure" />
        <intent>
            <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
        </intent>
    </queries>
    
    <application>
        <!-- Health Connect permission activity -->
        <activity
            android:name=".HealthPermissionActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />
        
        <!-- For supported versions through Android 13, create an activity to show the rationale
             of Health Connect permissions once users click the privacy policy link. -->
        <activity
            android:name=".PermissionsRationaleActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="androidx.health.ACTION_SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>
        
        <!-- For versions starting Android 14, create an activity alias to show the rationale
             of Health Connect permissions once users click the privacy policy link. -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".PermissionsRationaleActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Receive Health Connect change notifications -->
        <receiver
            android:name=".HealthChangeReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="androidx.health.connect.action.HEALTH_DATA_SYNC" />
            </intent-filter>
        </receiver>
    </application>
</manifest> 
